<?xml version="1.0" ?>
<model>
  <name>iris_with_ardupilot_uav2</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>
  <description>
    Clone of upstream ardupilot_gazebo iris_with_ardupilot with fdm_port_in
    offset to 9012 (instead of 9002), allowing two SITL instances to coexist
    in the same Gazebo world. Used by Stage 2.4 Multi-UAV demo
    (run_stage_2_4_multi_uav_demo.sh).
  </description>
</model>
