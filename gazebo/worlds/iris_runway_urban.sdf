    </model>

    <!-- =============== ROADS ============================================== -->
    <!-- Main avenue in SDF X direction (east-west in ENU) -->
    <model name="road_main_ns">
      <static>true</static>
      <pose>80 0 0.005 0 0 0</pose>
      <link name="link">
        <visual name="surface">
          <geometry><box><size>180 8 0.01</size></box></geometry>
          <material>
            <ambient>0.18 0.18 0.18 1</ambient>
            <diffuse>0.22 0.22 0.22 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Cross street at north=120m in SDF Y direction -->
    <model name="road_cross_n">
      <static>true</static>
      <pose>120 0 0.006 0 0 0</pose>
      <link name="link">
        <visual name="surface">
          <geometry><box><size>6 200 0.01</size></box></geometry>
          <material>
            <ambient>0.18 0.18 0.18 1</ambient>
            <diffuse>0.22 0.22 0.22 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Cross street at north=40m in SDF Y direction -->
    <model name="road_cross_s">
      <static>true</static>
      <pose>40 0 0.006 0 0 0</pose>
