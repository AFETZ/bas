    </model>

    <!-- Small commercial: 18×10×8м -->
    <model name="bldg_commercial_1">
      <static>true</static>
      <pose>30 60 4 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>18 10 8</size></box></geometry></collision>
        <visual name="visual">
          <geometry><box><size>18 10 8</size></box></geometry>
