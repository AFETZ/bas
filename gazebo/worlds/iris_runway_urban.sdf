      <static>true</static>
      <pose>25 -30 0 0 0 0</pose>
      <link name="link">
        <visual name="trunk">
          <pose>0 0 1.5 0 0 0</pose>
          <geometry><cylinder><radius>0.30</radius><length>3.0</length></cylinder></geometry>
          <material><ambient>0.35 0.22 0.12 1</ambient><diffuse>0.40 0.26 0.15 1</diffuse></material>
        </visual>
        <visual name="canopy">
          <pose>0 0 6.0 0 0 0</pose>
          <geometry><sphere><radius>3.5</radius></sphere></geometry>
          <material><ambient>0.18 0.45 0.20 1</ambient><diffuse>0.22 0.55 0.25 1</diffuse></material>
