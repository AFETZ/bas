    </model>

    <model name="vehicle_02">
      <static>true</static>
      <pose>80 -12 0.7 0 0 3.14159</pose>
      <link name="link">
        <visual name="body"><pose>0 0 0.6 0 0 0</pose>
          <geometry><box><size>4.6 1.8 1.4</size></box></geometry>
          <material><ambient>0.55 0.15 0.15 1</ambient><diffuse>0.70 0.20 0.20 1</diffuse><specular>0.5 0.5 0.5 1</specular></material></visual>
        <visual name="roof"><pose>-0.2 0 1.6 0 0 0</pose>
          <geometry><box><size>2.8 1.6 0.4</size></box></geometry>
          <material><ambient>0.30 0.10 0.10 1</ambient><diffuse>0.40 0.15 0.15 1</diffuse></material></visual>
      </link>
    </model>

    <!-- =============== UAV ================================================ -->
    <include>
      <uri>model://iris_with_gimbal</uri>
      <pose degrees="true">0 0 0.195 0 0 90</pose>
    </include>
  </world>
</sdf>
