    <!-- =============== PARKED VEHICLES (cars) ============================= -->
    <model name="vehicle_01">
      <static>true</static>
      <pose>80 12 0.7 0 0 0</pose>
      <link name="link">
        <visual name="body"><pose>0 0 0.6 0 0 0</pose>
          <geometry><box><size>4.2 1.7 1.2</size></box></geometry>
